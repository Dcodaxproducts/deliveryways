generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS_ADMIN
  BRANCH_ADMIN
  CUSTOMER
}

enum AddressRefType {
  TENANT
  RESTAURANT
  BRANCH
  USER
}

enum StockMovementType {
  IN
  OUT
  ADJUST
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REJECTED
}

enum CouponStatus {
  ACTIVE
  SUSPENDED
}

enum CouponDiscountType {
  FLAT
  PERCENTAGE
}

enum OrderType {
  DELIVERY
  TAKEAWAY
  DINE_IN
}

enum PaymentMethod {
  COD
  STRIPE
  EASYPAISA
  JAZZCASH
  BANK_TRANSFER
}

model Tenant {
  id             String    @id @default(cuid())
  name           String
  ownerId        String?   @map("owner_id")
  slug           String    @unique
  bio            String?
  logoUrl        String?   @map("logo_url")
  socialLinks    Json?     @map("social_links")
  brandingConfig Json?     @map("branding_config")
  settings       Json?
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  owner       User?        @relation("TenantOwner", fields: [ownerId], references: [id])
  restaurants Restaurant[]
  branches    Branch[]
  users       User[]       @relation("TenantUsers")
  coupons     Coupon[]
  orders      Order[]

  @@map("tenants")
}

model Restaurant {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  name           String
  slug           String    @unique
  logoUrl        String?   @map("logo_url")
  customDomain   String?   @map("custom_domain")
  tagline        String?
  bio            String?
  supportContact Json?     @map("support_contact")
  branding       Json?
  socialMedia    Json?     @map("social_media")
  settings       Json?
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  branches            Branch[]
  users               User[]              @relation("RestaurantUsers")
  restaurantMenus     RestaurantMenu[]
  menuCategories      MenuCategory[]
  menuItems           MenuItem[]
  modifierGroups      ModifierGroup[]
  inventoryCategories InventoryCategory[]
  inventoryItems      InventoryItem[]
  coupons             Coupon[]
  orders              Order[]

  @@map("restaurants")
}

model Branch {
  id           String    @id @default(cuid())
  restaurantId String    @map("restaurant_id")
  tenantId     String    @map("tenant_id")
  name         String
  coverImage   String?   @map("cover_image")
  description  String?
  settings     Json?
  isMain       Boolean   @default(false) @map("is_main")
  managerId    String?   @map("manager_id")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  restaurant         Restaurant               @relation(fields: [restaurantId], references: [id])
  tenant             Tenant                   @relation(fields: [tenantId], references: [id])
  manager            User?                    @relation("BranchManager", fields: [managerId], references: [id])
  users              User[]                   @relation("BranchUsers")
  menuItemOverrides  BranchMenuItemOverride[]
  categoryOverrides  BranchCategoryOverride[]
  inventoryMovements InventoryMovement[]
  coupons            Coupon[]
  orders             Order[]

  @@map("branches")
}

model Address {
  id             String         @id @default(cuid())
  tenantId       String         @map("tenant_id")
  referenceId    String         @map("reference_id")
  refType        AddressRefType @map("ref_type")
  street         String
  area           String?
  city           String
  state          String
  country        String
  lat            Decimal?       @db.Decimal(10, 7)
  lng            Decimal?       @db.Decimal(10, 7)
  isActive       Boolean        @default(true) @map("is_active")
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deliveryOrders Order[]        @relation("OrderDeliveryAddress")

  @@index([referenceId, refType])
  @@map("addresses")
}

model User {
  id                        String    @id @default(cuid())
  email                     String
  password                  String
  role                      UserRole
  isVerified                Boolean   @default(false) @map("is_verified")
  isApproved                Boolean   @default(false) @map("is_approved")
  verificationToken         String?   @map("verification_token")
  verificationOtp           String?   @map("verification_otp")
  verificationOtpExpiresAt  DateTime? @map("verification_otp_expires_at") @db.Timestamptz
  verificationOtpAttempts   Int       @default(0) @map("verification_otp_attempts")
  resetPasswordOtp          String?   @map("reset_password_otp")
  resetPasswordOtpExpiresAt DateTime? @map("reset_password_otp_expires_at") @db.Timestamptz
  resetPasswordOtpAttempts  Int       @default(0) @map("reset_password_otp_attempts")
  refreshTokenHash          String?   @map("refresh_token_hash")
  deleteAfter               DateTime? @map("delete_after") @db.Timestamptz
  tenantId                  String?   @map("tenant_id")
  restaurantId              String?   @map("restaurant_id")
  branchId                  String?   @map("branch_id")
  isActive                  Boolean   @default(true) @map("is_active")
  deletedAt                 DateTime? @map("deleted_at") @db.Timestamptz
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenantOwned      Tenant[]            @relation("TenantOwner")
  tenant           Tenant?             @relation("TenantUsers", fields: [tenantId], references: [id])
  restaurant       Restaurant?         @relation("RestaurantUsers", fields: [restaurantId], references: [id])
  branch           Branch?             @relation("BranchUsers", fields: [branchId], references: [id])
  managedBranches  Branch[]            @relation("BranchManager")
  profile          Profile?
  createdMovements InventoryMovement[] @relation("MovementCreatedBy")
  customerOrders   Order[]             @relation("OrderCustomer")
  couponUsages     CouponUsage[]

  @@unique([email])
  @@map("users")
}

model Profile {
  id        String    @id @default(cuid())
  userId    String    @unique @map("user_id")
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  avatarUrl String?   @map("avatar_url")
  phone     String?
  bio       String?
  metadata  Json?
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("profiles")
}

model MenuCategory {
  id               String    @id @default(cuid())
  restaurantId     String    @map("restaurant_id")
  parentCategoryId String?   @map("parent_category_id")
  name             String
  slug             String
  description      String?
  imageUrl         String?   @map("image_url")
  sortOrder        Int       @default(0) @map("sort_order")
  isActive         Boolean   @default(true) @map("is_active")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  restaurant   Restaurant               @relation(fields: [restaurantId], references: [id])
  parent       MenuCategory?            @relation("MenuCategoryTree", fields: [parentCategoryId], references: [id])
  children     MenuCategory[]           @relation("MenuCategoryTree")
  items        MenuItem[]
  overrides    BranchCategoryOverride[]
  couponScopes Coupon[]

  @@unique([restaurantId, slug])
  @@map("menu_categories")
}

model MenuItem {
  id              String    @id @default(cuid())
  restaurantId    String    @map("restaurant_id")
  categoryId      String    @map("category_id")
  name            String
  slug            String
  description     String?
  imageUrl        String?   @map("image_url")
  sku             String?
  basePrice       Decimal   @default(0) @map("base_price") @db.Decimal(10, 2)
  prepTimeMinutes Int?      @map("prep_time_minutes")
  dietaryFlags    Json?     @map("dietary_flags")
  allergenFlags   Json?     @map("allergen_flags")
  isActive        Boolean   @default(true) @map("is_active")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  restaurant      Restaurant               @relation(fields: [restaurantId], references: [id])
  category        MenuCategory             @relation(fields: [categoryId], references: [id])
  menuLinks       RestaurantMenuItem[]
  variations      MenuItemVariation[]
  modifierLinks   MenuItemModifierGroup[]
  branchOverrides BranchMenuItemOverride[]
  recipes         MenuItemRecipe[]
  couponScopes    Coupon[]
  orderItems      OrderItem[]

  @@unique([restaurantId, slug])
  @@unique([restaurantId, sku])
  @@map("menu_items")
}

model RestaurantMenu {
  id          String    @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  name        String
  slug        String
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  restaurant Restaurant         @relation(fields: [restaurantId], references: [id])
  items      RestaurantMenuItem[]

  @@unique([restaurantId, slug])
  @@map("restaurant_menus")
}

model RestaurantMenuItem {
  id               String    @id @default(cuid())
  restaurantMenuId String    @map("restaurant_menu_id")
  menuItemId       String    @map("menu_item_id")
  sortOrder        Int       @default(0) @map("sort_order")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  restaurantMenu RestaurantMenu @relation(fields: [restaurantMenuId], references: [id])
  menuItem       MenuItem        @relation(fields: [menuItemId], references: [id])

  @@unique([restaurantMenuId, menuItemId])
  @@map("restaurant_menu_items")
}

model MenuItemVariation {
  id         String    @id @default(cuid())
  menuItemId String    @map("menu_item_id")
  name       String
  sku        String?
  price      Decimal   @default(0) @db.Decimal(10, 2)
  sortOrder  Int       @default(0) @map("sort_order")
  isDefault  Boolean   @default(false) @map("is_default")
  isActive   Boolean   @default(true) @map("is_active")
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([menuItemId, name])
  @@map("menu_item_variations")
}

model ModifierGroup {
  id           String    @id @default(cuid())
  restaurantId String    @map("restaurant_id")
  name         String
  description  String?
  minSelect    Int       @default(0) @map("min_select")
  maxSelect    Int       @default(1) @map("max_select")
  isRequired   Boolean   @default(false) @map("is_required")
  sortOrder    Int       @default(0) @map("sort_order")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  restaurant Restaurant              @relation(fields: [restaurantId], references: [id])
  modifiers  Modifier[]
  itemLinks  MenuItemModifierGroup[]

  @@unique([restaurantId, name])
  @@map("modifier_groups")
}

model Modifier {
  id              String    @id @default(cuid())
  modifierGroupId String    @map("modifier_group_id")
  name            String
  priceDelta      Decimal   @default(0) @map("price_delta") @db.Decimal(10, 2)
  sortOrder       Int       @default(0) @map("sort_order")
  isActive        Boolean   @default(true) @map("is_active")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id])

  @@unique([modifierGroupId, name])
  @@map("modifiers")
}

model MenuItemModifierGroup {
  id              String @id @default(cuid())
  menuItemId      String @map("menu_item_id")
  modifierGroupId String @map("modifier_group_id")
  sortOrder       Int    @default(0) @map("sort_order")

  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id])
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id])

  @@unique([menuItemId, modifierGroupId])
  @@map("menu_item_modifier_groups")
}

model BranchMenuItemOverride {
  id            String   @id @default(cuid())
  branchId      String   @map("branch_id")
  menuItemId    String   @map("menu_item_id")
  isAvailable   Boolean  @default(true) @map("is_available")
  priceOverride Decimal? @map("price_override") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  branch   Branch   @relation(fields: [branchId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([branchId, menuItemId])
  @@map("branch_menu_item_overrides")
}

model BranchCategoryOverride {
  id             String   @id @default(cuid())
  branchId       String   @map("branch_id")
  menuCategoryId String   @map("menu_category_id")
  isVisible      Boolean  @default(true) @map("is_visible")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  branch       Branch       @relation(fields: [branchId], references: [id])
  menuCategory MenuCategory @relation(fields: [menuCategoryId], references: [id])

  @@unique([branchId, menuCategoryId])
  @@map("branch_category_overrides")
}

model InventoryCategory {
  id           String    @id @default(cuid())
  restaurantId String    @map("restaurant_id")
  name         String
  slug         String
  description  String?
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  items      InventoryItem[]

  @@unique([restaurantId, slug])
  @@map("inventory_categories")
}

model InventoryItem {
  id                  String    @id @default(cuid())
  restaurantId        String    @map("restaurant_id")
  inventoryCategoryId String?   @map("inventory_category_id")
  name                String
  sku                 String?
  unit                String
  currentQty          Decimal   @default(0) @map("current_qty") @db.Decimal(12, 3)
  reorderLevel        Decimal?  @map("reorder_level") @db.Decimal(12, 3)
  costPerUnit         Decimal?  @map("cost_per_unit") @db.Decimal(10, 2)
  isActive            Boolean   @default(true) @map("is_active")
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  restaurant Restaurant          @relation(fields: [restaurantId], references: [id])
  category   InventoryCategory?  @relation(fields: [inventoryCategoryId], references: [id])
  movements  InventoryMovement[]
  recipes    MenuItemRecipe[]

  @@unique([restaurantId, sku])
  @@map("inventory_items")
}

model InventoryMovement {
  id              String            @id @default(cuid())
  inventoryItemId String            @map("inventory_item_id")
  branchId        String?           @map("branch_id")
  movementType    StockMovementType @map("movement_type")
  quantity        Decimal           @db.Decimal(12, 3)
  note            String?
  referenceType   String?           @map("reference_type")
  referenceId     String?           @map("reference_id")
  createdByUserId String?           @map("created_by_user_id")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  branch        Branch?       @relation(fields: [branchId], references: [id])
  createdBy     User?         @relation("MovementCreatedBy", fields: [createdByUserId], references: [id])

  @@map("inventory_movements")
}

model MenuItemRecipe {
  id              String   @id @default(cuid())
  menuItemId      String   @map("menu_item_id")
  inventoryItemId String   @map("inventory_item_id")
  quantity        Decimal  @db.Decimal(12, 3)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([menuItemId, inventoryItemId])
  @@map("menu_item_recipes")
}

model Coupon {
  id                 String             @id @default(cuid())
  tenantId           String             @map("tenant_id")
  restaurantId       String             @map("restaurant_id")
  branchId           String?            @map("branch_id")
  code               String
  title              String
  description        String?
  status             CouponStatus       @default(ACTIVE)
  discountType       CouponDiscountType @map("discount_type")
  discountValue      Decimal            @map("discount_value") @db.Decimal(10, 2)
  maxDiscountAmount  Decimal?           @map("max_discount_amount") @db.Decimal(10, 2)
  minOrderAmount     Decimal?           @map("min_order_amount") @db.Decimal(10, 2)
  maxUses            Int?               @map("max_uses")
  maxUsesPerCustomer Int?               @map("max_uses_per_customer")
  usedCount          Int                @default(0) @map("used_count")
  startsAt           DateTime           @map("starts_at") @db.Timestamptz
  expiresAt          DateTime           @map("expires_at") @db.Timestamptz
  scopeMenuItemId    String?            @map("scope_menu_item_id")
  scopeCategoryId    String?            @map("scope_category_id")
  isActive           Boolean            @default(true) @map("is_active")
  deletedAt          DateTime?          @map("deleted_at") @db.Timestamptz
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  branch        Branch?       @relation(fields: [branchId], references: [id])
  scopeMenuItem MenuItem?     @relation(fields: [scopeMenuItemId], references: [id])
  scopeCategory MenuCategory? @relation(fields: [scopeCategoryId], references: [id])
  orders        Order[]
  usages        CouponUsage[]

  @@unique([restaurantId, code])
  @@index([restaurantId, status, isActive])
  @@index([branchId])
  @@map("coupons")
}

model CouponUsage {
  id         String   @id @default(cuid())
  couponId   String   @map("coupon_id")
  customerId String   @map("customer_id")
  orderId    String?  @map("order_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  coupon   Coupon @relation(fields: [couponId], references: [id])
  customer User   @relation(fields: [customerId], references: [id])
  order    Order? @relation(fields: [orderId], references: [id])

  @@unique([couponId, orderId])
  @@index([couponId, customerId])
  @@map("coupon_usages")
}

model Order {
  id                String        @id @default(cuid())
  tenantId          String        @map("tenant_id")
  restaurantId      String        @map("restaurant_id")
  branchId          String        @map("branch_id")
  customerId        String        @map("customer_id")
  couponId          String?       @map("coupon_id")
  deliveryAddressId String?       @map("delivery_address_id")
  orderType         OrderType     @map("order_type")
  paymentMethod     PaymentMethod @map("payment_method")
  status            OrderStatus   @default(PLACED)
  subtotal          Decimal       @db.Decimal(10, 2)
  taxAmount         Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  deliveryFee       Decimal       @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  discountAmount    Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount       Decimal       @map("total_amount") @db.Decimal(10, 2)
  customerNote      String?       @map("customer_note")
  cancelledAt       DateTime?     @map("cancelled_at") @db.Timestamptz
  cancelledByUserId String?       @map("cancelled_by_user_id")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id])
  branch          Branch        @relation(fields: [branchId], references: [id])
  customer        User          @relation("OrderCustomer", fields: [customerId], references: [id])
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  deliveryAddress Address?      @relation("OrderDeliveryAddress", fields: [deliveryAddressId], references: [id])
  items           OrderItem[]
  couponUsages    CouponUsage[]

  @@index([branchId, status, createdAt])
  @@index([customerId, createdAt])
  @@map("orders")
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String   @map("order_id")
  menuItemId        String   @map("menu_item_id")
  menuItemName      String   @map("menu_item_name")
  variationId       String?  @map("variation_id")
  variationName     String?  @map("variation_name")
  unitPrice         Decimal  @map("unit_price") @db.Decimal(10, 2)
  quantity          Int
  lineTotal         Decimal  @map("line_total") @db.Decimal(10, 2)
  note              String?
  snapshotModifiers Json?    @map("snapshot_modifiers")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@map("order_items")
}
