# ============================================================
# DeliveryWays - Environment Configuration
# ============================================================

# App
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:4200

# Database
DATABASE_URL=postgresql://deliveryways:deliveryways@127.0.0.1:5434/deliveryways

# Email Verification
EMAIL_ENABLED=false
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=example@domain.com
MAIL_PASSWORD=change-me
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=example@domain.com

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# AWS S3 Uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=deliveryway
AWS_PUBLIC_BASE_URL=
AWS_PRESIGNED_UPLOAD_EXPIRY_SECONDS=300
